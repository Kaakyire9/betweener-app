{
  "cli": {
    "version": ">= 16.26.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "image": "latest",
        "cache": {
          "disabled": true
        }
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "development",
        "EXPO_USE_POD_REPO_UPDATE": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "preview",
        "EXPO_PUBLIC_ENABLE_INTERNAL_TOOLS": "false",
        "EXPO_USE_POD_REPO_UPDATE": "1"
      },
      "ios": {
        "image": "latest",
        "cache": {
          "disabled": true
        }
      }
    },
    "playInternal": {
      "distribution": "store",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "preview",
        "EXPO_PUBLIC_ENABLE_INTERNAL_TOOLS": "false",
        "EXPO_USE_POD_REPO_UPDATE": "1"
      }
    },
    "playVerification": {
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a -Pandroid.enableMinifyInReleaseBuilds=true -Pandroid.enableShrinkResourcesInReleaseBuilds=true"
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "production",
        "EXPO_PUBLIC_ENABLE_INTERNAL_TOOLS": "false",
        "GOOGLE_PLAY_PACKAGE_VERIFICATION_TOKEN": "CSMCKSCOJWUC2AAAAAAAAAAAAA",
        "EXPO_USE_POD_REPO_UPDATE": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "production",
        "EXPO_PUBLIC_ENABLE_INTERNAL_TOOLS": "false",
        "EXPO_USE_POD_REPO_UPDATE": "1"
      },
      "ios": {
        "image": "latest"
      }
    }
  },
  "submit": {
    "playInternal": {},
    "production": {}
  }
}
